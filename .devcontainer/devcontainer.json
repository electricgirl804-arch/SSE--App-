        st.write(f"📊 تقرير: المنظومة متوافقة مع معايير SSE في {city}.")
        
        # باركود الاعتماد
        qr = qrcode.make(f"SSE Certified Product: {prod_type} | Location: {city}")
        buf = BytesIO()
        qr.save(buf, format="PNG")
        st.image(buf.getvalue(), caption="باركود الاعتماد النهائي")

