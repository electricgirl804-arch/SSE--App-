# 5. البيانات والمدن
sudan_cities = {"الخرطوم": {"lat": 15.50, "lon": 32.55}, "عطبرة": {"lat": 17.68, "lon": 33.95}, "بورتسودان": {"lat": 19.61, "lon": 37.22}}

