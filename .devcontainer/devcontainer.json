# 3. دالة الإنذار الصوتي
def play_alert(text):
    tts = gTTS(text=text, lang='ar')
    fp = BytesIO()
    tts.write_to_fp(fp)
    audio_base64 = base64.b64encode(fp.getvalue()).decode()
    st.markdown(f'<audio autoplay="true" src="data:audio/mp3;base64,{audio_base64}"></audio>', unsafe_allow_html=True)

# 4. الأفاتار الترحيبي
